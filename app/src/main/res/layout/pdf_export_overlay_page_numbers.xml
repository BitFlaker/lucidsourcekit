<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="595px"
    android:layout_height="842px"
    android:paddingTop="32px"
    android:paddingHorizontal="48px"
    android:paddingBottom="32px"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <View
        android:id="@+id/vw_footer_separator"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginBottom="4px"
        android:background="#000"
        app:layout_constraintBottom_toTopOf="@+id/txt_page_counter"/>

    <TextView
        android:id="@+id/txt_print_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2px"
        android:textSize="12px"
        android:textColor="#000"
        android:text="{PRINT_DATE} {PRINT_TIME}"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/vw_footer_separator" />

    <TextView
        android:id="@+id/txt_page_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="2px"
        android:textSize="12px"
        android:textColor="#000"
        android:text="Page {CURRENT_PAGE} / {TOTAL_PAGES}"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/vw_footer_separator" />
</androidx.constraintlayout.widget.ConstraintLayout>